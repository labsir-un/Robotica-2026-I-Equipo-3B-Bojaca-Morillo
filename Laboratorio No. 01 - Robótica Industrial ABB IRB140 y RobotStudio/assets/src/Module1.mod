    !***********************************************************
    !
    ! Procedimiento Main
    !
    !   Este es el punto de entrada de su programa
    !
    !***********************************************************
    PROC main()
        !MoveAbsJ Home_ABS, v1000, z1, tool0;
        !Path_10;
        MoveAbsJ Home_ABS, v300, z1, tool0;
           
        TPErase;
        TPWrite "INICIO PROGRAMA";
        TPWrite "APAGADO BANDA TRANASPORTADORA";
        Reset DO_02;
        Reset DO_01;
        RESET BWD_Conveyor;
        RESET FWD_Conveyor;
        
        WHILE TRUE DO   
            IF DI_03 = 1 THEN
                RESET BWD_Conveyor;
                Reset FWD_Conveyor;
                Set BWD_Conveyor;
                WaitTime 2; 
                Reset FWD_Conveyor;
                Reset BWD_Conveyor;
            ENDIF
            
            IF DI_01 = 1 AND DI_02 = 0 THEN
                TPWrite "ENCIENDE BANDA TRANASPORTADORA";
                Set FWD_Conveyor;
                WaitTime 2.03;  !2.05 el mejor hasta ahora
                TPWrite "APAGADO BANDA TRANASPORTADORA";
                Reset FWD_Conveyor;
                TPWrite "INICIANDO DECORADO";
                Set DO_01;
                Path_10;
                TPWrite "DECORADO FINALIZADO";
                Reset DO_01;
                MoveAbsJ Home_ABS,v1000,z1,tool0;
                TPWrite "ENCENDIDO BANDA TRANASPORTADORA";
                Set FWD_Conveyor;
                WaitTime 8;
                TPWrite "APAGADO BANDA TRANASPORTADORA";
                Reset FWD_Conveyor;
                
            ELSEIF DI_01 = 0 AND DI_02=1 THEN
                Set DO_02;
                TPWrite "RUTINA CAMBIO DE HERRAMIENTA";
                MoveAbsJ Mantenimiento_Point,v1000,z1,tool0;
                TPWrite "PELIGRO";  
                TPWrite "OPERARIO CERCA A HERRAMIENTA";   
                TPWrite "PRESIONE LOS DOS BOTONES PARA CONTINUAR EL PROGRAMA"; 
                WaitDI DI_01,1;
                WaitDI DI_02,1;
                Reset DO_02;
                TPWrite "REANUDANDO PROGRAMA"; 
                WaitTime 3;
                MoveAbsJ Home_ABS,v1000,z1,tool0;
            ELSEIF DI_01 = 0 AND DI_02=0 THEN
                TPWrite "ESPERANDO INSTRUCCIÓNES";  
            ELSEIF DI_01 = 1 AND DI_02=1 THEN
                TPWrite "ERROR";   
                TPWrite "NO DEBE PRESIONAR AMBAS ENTRADAS AL TIEMPO";   
            ENDIF
            
        ENDWHILE
        
        
        
    ENDPROC
    
    PROC Test_Caja()
        RESET BWD_Conveyor;
        Reset FWD_Conveyor;
        Set BWD_Conveyor;
        WaitTime 2; 
        Reset FWD_Conveyor;
        Reset BWD_Conveyor;
    ENDPROC
    
    PROC Aristas_Caja()
        MoveL Target_10,v1000,z1,Marcador_TCP\WObj:=Caja;
        MoveL Target_20,v1000,z1,Marcador_TCP\WObj:=Caja;
        MoveL Target_30,v1000,z1,Marcador_TCP\WObj:=Caja;
        MoveL Target_40,v1000,z1,Marcador_TCP\WObj:=Caja;
    ENDPROC
    PROC MAFE()

    ENDPROC
